# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────────────
# Replace with your Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/chatapp?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── URLs ─────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# Your Render backend URL (no trailing slash)
# This is used to build correct file upload URLs
BACKEND_URL=https://your-api.onrender.com
